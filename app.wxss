page {
  --paper-base: #efe4c8;
  --paper-soft: #f6edd7;
  --paper-panel: #f3e7cd;
  --paper-deep: #e2cfab;
  --ink-main: #1f1a17;
  --ink-soft: #5e5141;
  --ink-faint: #857661;
  --jade-main: #203f3a;
  --jade-soft: #365d57;
  --clay-main: #8c4d36;
  --danger-main: #8f2f2a;
  --danger-soft: #c96f57;
  --line-main: rgba(68, 53, 36, 0.18);
  --shadow-soft: 0 16rpx 36rpx rgba(44, 30, 16, 0.1);
  --shadow-deep: 0 24rpx 48rpx rgba(44, 30, 16, 0.16);
  background:
    radial-gradient(circle at top, rgba(255, 250, 239, 0.8), transparent 42%),
    linear-gradient(180deg, #f5ecd8 0%, var(--paper-base) 52%, #e8d7b7 100%);
  color: var(--ink-main);
  font-family: "PingFang SC", "Noto Serif SC", "Microsoft YaHei", serif;
}

.page-shell,
.scroll-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx 36rpx;
  position: relative;
}

.scroll-page::before {
  content: "";
  position: absolute;
  inset: 12rpx;
  border: 2rpx solid rgba(80, 61, 37, 0.12);
  border-radius: 28rpx;
  pointer-events: none;
}

.scroll-hero,
.panel {
  position: relative;
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid var(--line-main);
  background:
    linear-gradient(180deg, rgba(255, 249, 237, 0.94) 0%, rgba(240, 226, 196, 0.96) 100%);
  box-shadow: var(--shadow-soft);
  overflow: hidden;
}

.scroll-hero::before,
.panel::before {
  content: "";
  position: absolute;
  inset: 10rpx;
  border: 2rpx solid rgba(80, 61, 37, 0.08);
  border-radius: 22rpx;
  pointer-events: none;
}

.scroll-title,
.section-title {
  position: relative;
  margin-bottom: 14rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: var(--ink-main);
}

.scroll-kicker {
  margin-bottom: 10rpx;
  color: var(--clay-main);
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.scroll-subtitle {
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.7;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.badge-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(32, 63, 58, 0.1);
  color: var(--jade-main);
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.resource-strip {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 4rpx;
}

.resource-chip,
.entry-card,
.choice-note {
  flex: 0 0 auto;
  min-width: 180rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 235, 0.9);
  border: 2rpx solid rgba(89, 66, 43, 0.12);
}

.entry-card {
  display: block;
  width: 100%;
  margin-bottom: 16rpx;
  box-shadow: 0 10rpx 22rpx rgba(44, 30, 16, 0.08);
}

.entry-card-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: var(--ink-main);
}

.entry-card-copy,
.muted-text {
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.detail-cell {
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 251, 243, 0.7);
}

.detail-label {
  display: block;
  color: var(--ink-faint);
  font-size: 22rpx;
  margin-bottom: 6rpx;
}

.detail-value {
  color: var(--ink-main);
  font-size: 30rpx;
  font-weight: 600;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.primary-button,
.secondary-button,
.ghost-button {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 28rpx;
  line-height: 1.2;
}

.primary-button {
  background: linear-gradient(135deg, var(--jade-main) 0%, var(--jade-soft) 100%);
  color: #fff7ea;
  box-shadow: 0 12rpx 24rpx rgba(32, 63, 58, 0.24);
}

.secondary-button {
  background: rgba(140, 77, 54, 0.1);
  color: var(--clay-main);
  border: 2rpx solid rgba(140, 77, 54, 0.2);
}

.ghost-button {
  background: rgba(255, 251, 243, 0.76);
  color: var(--ink-main);
  border: 2rpx solid rgba(89, 66, 43, 0.14);
}

.primary-button[disabled],
.secondary-button[disabled],
.ghost-button[disabled] {
  opacity: 0.45;
  box-shadow: none;
}

.danger-text {
  color: var(--danger-main);
  font-size: 24rpx;
  line-height: 1.6;
}

.status-note {
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(140, 77, 54, 0.08);
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.status-note.danger {
  background: rgba(143, 47, 42, 0.08);
  color: var(--danger-main);
}

.section-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
