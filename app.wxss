page {
  background:
    radial-gradient(circle at top, rgba(255, 250, 239, 0.8), transparent 42%),
    linear-gradient(180deg, #f5ecd8 0%, #efe4c8 52%, #e8d7b7 100%);
  color: #1f1a17;
  font-family: "PingFang SC", "Noto Serif SC", "Microsoft YaHei", serif;
}

.page-shell,
.scroll-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx 36rpx;
  position: relative;
}

.scroll-page:before {
  content: "";
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  left: 12rpx;
  border: 2rpx solid rgba(80, 61, 37, 0.12);
  border-radius: 28rpx;
  pointer-events: none;
}

.scroll-hero,
.panel {
  position: relative;
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(68, 53, 36, 0.18);
  background:
    linear-gradient(180deg, rgba(255, 249, 237, 0.94) 0%, rgba(240, 226, 196, 0.96) 100%);
  box-shadow: 0 16rpx 36rpx rgba(44, 30, 16, 0.1);
  overflow: hidden;
}

.scroll-hero:before,
.panel:before {
  content: "";
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  left: 10rpx;
  border: 2rpx solid rgba(80, 61, 37, 0.08);
  border-radius: 22rpx;
  pointer-events: none;
}

.scroll-title,
.section-title {
  position: relative;
  margin-bottom: 14rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #1f1a17;
}

.scroll-kicker {
  margin-bottom: 10rpx;
  color: #8c4d36;
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.scroll-subtitle {
  color: #5e5141;
  font-size: 24rpx;
  line-height: 1.7;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
}

.badge-pill {
  display: flex;
  align-items: center;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(32, 63, 58, 0.1);
  color: #203f3a;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.resource-strip {
  display: flex;
  overflow-x: auto;
  padding-bottom: 4rpx;
}

.resource-chip,
.entry-card,
.choice-note {
  flex: 0 0 auto;
  min-width: 180rpx;
  margin-right: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 235, 0.9);
  border: 2rpx solid rgba(89, 66, 43, 0.12);
}

.entry-card {
  display: block;
  width: 100%;
  margin-right: 0;
  margin-bottom: 16rpx;
  box-shadow: 0 10rpx 22rpx rgba(44, 30, 16, 0.08);
}

.entry-card-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: #1f1a17;
}

.entry-card-copy,
.muted-text {
  color: #5e5141;
  font-size: 24rpx;
  line-height: 1.6;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
  margin-right: -16rpx;
}

.detail-cell {
  box-sizing: border-box;
  width: 50%;
  padding: 18rpx;
  padding-right: 34rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 251, 243, 0.7);
}

.detail-label {
  display: block;
  color: #857661;
  font-size: 22rpx;
  margin-bottom: 6rpx;
}

.detail-value {
  color: #1f1a17;
  font-size: 30rpx;
  font-weight: 600;
}

.action-stack {
  display: flex;
  flex-direction: column;
}

.primary-button,
.secondary-button,
.ghost-button {
  width: 100%;
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 28rpx;
  line-height: 1.2;
}

.primary-button {
  background: linear-gradient(135deg, #203f3a 0%, #365d57 100%);
  color: #fff7ea;
  box-shadow: 0 12rpx 24rpx rgba(32, 63, 58, 0.24);
}

.secondary-button {
  background: rgba(140, 77, 54, 0.1);
  color: #8c4d36;
  border: 2rpx solid rgba(140, 77, 54, 0.2);
}

.ghost-button {
  background: rgba(255, 251, 243, 0.76);
  color: #1f1a17;
  border: 2rpx solid rgba(89, 66, 43, 0.14);
}

.primary-button[disabled],
.secondary-button[disabled],
.ghost-button[disabled] {
  opacity: 0.45;
  box-shadow: none;
}

.danger-text {
  color: #8f2f2a;
  font-size: 24rpx;
  line-height: 1.6;
}

.status-note {
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(140, 77, 54, 0.08);
  color: #5e5141;
  font-size: 24rpx;
  line-height: 1.6;
}

.status-note.danger {
  background: rgba(143, 47, 42, 0.08);
  color: #8f2f2a;
}

.section-stack {
  display: flex;
  flex-direction: column;
}

.section-stack > * {
  margin-bottom: 18rpx;
}

.action-stack > *:last-child,
.section-stack > *:last-child,
.resource-strip > *:last-child {
  margin-bottom: 0;
  margin-right: 0;
}
