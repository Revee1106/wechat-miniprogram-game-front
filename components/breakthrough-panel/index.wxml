<view class="panel">
  <view class="section-title">Breakthrough</view>
  <block wx:if="{{player}}">
    <view class="panel-row">Realm: {{player.realm}}</view>
    <view class="panel-row">EXP: {{player.cultivation_exp}}</view>
    <view class="panel-row">Spirit Stones: {{resources.spirit_stone}}</view>
    <button
      class="primary-button"
      bindtap="submitBreakthrough"
      disabled="{{!canBreakthrough}}"
    >
      Attempt Breakthrough
    </button>
  </block>
</view>
