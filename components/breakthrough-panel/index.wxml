<view class="panel">
  <view class="section-title">突破</view>
  <block wx:if="{{player}}">
    <view class="panel-row">境界：{{player.realm}}</view>
    <view class="panel-row">修为：{{player.cultivation_exp}}</view>
    <view class="panel-row">灵石：{{resources.spirit_stone}}</view>
    <button
      class="primary-button"
      bindtap="submitBreakthrough"
      disabled="{{!canBreakthrough}}"
    >
      尝试突破
    </button>
  </block>
</view>
