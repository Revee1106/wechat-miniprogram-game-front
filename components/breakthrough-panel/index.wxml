<view class="panel">
  <view class="scroll-kicker">破境仪轨</view>
  <view class="section-title">冲关所需</view>
  <block wx:if="{{player}}">
    <view class="detail-grid">
      <view class="detail-cell">
        <text class="detail-label">当前境界</text>
        <text wx:if="{{player.realm_display_name}}" class="detail-value">{{player.realm_display_name}}</text>
        <text wx:else class="detail-value">{{player.realm}}</text>
      </view>
      <view class="detail-cell">
        <text class="detail-label">现有修为</text>
        <text class="detail-value">{{player.cultivation_exp}}</text>
      </view>
      <view class="detail-cell">
        <text class="detail-label">灵石储备</text>
        <text class="detail-value">{{resources.spirit_stone}}</text>
      </view>
      <view class="detail-cell">
        <text class="detail-label">破境门槛</text>
        <text class="detail-value">修为 {{breakthroughTargetExp}}</text>
        <text class="detail-value"> / 灵石 {{breakthroughTargetSpiritStone}}</text>
      </view>
    </view>
    <view class="status-note">{{hint}}</view>
    <button
      class="primary-button"
      style="margin-top: 18rpx;"
      bindtap="submitBreakthrough"
      disabled="{{!canBreakthrough}}"
    >
      尝试破境
    </button>
  </block>
  <view wx:else class="status-note">No player data.</view>
</view>
