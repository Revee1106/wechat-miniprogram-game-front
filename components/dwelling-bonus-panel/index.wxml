<view class="panel" wx:if="{{facility}}">
  <view class="scroll-kicker">{{facility.display_name}}</view>
  <view class="section-title">设施详情</view>
  <view class="detail-grid">
    <view class="detail-cell">
      <text class="detail-label">设施标识</text>
      <text class="detail-value">{{facility.facility_id}}</text>
    </view>
    <view class="detail-cell">
      <text class="detail-label">当前等级</text>
      <text class="detail-value">{{facility.level}} / {{facility.max_level}}</text>
    </view>
    <view class="detail-cell">
      <text class="detail-label">运行状态</text>
      <text class="detail-value">{{facility.status}}</text>
    </view>
    <view class="detail-cell">
      <text class="detail-label">维护费用</text>
      <text class="detail-value">{{maintenanceSpiritStoneText}} 灵石</text>
    </view>
    <view class="detail-cell">
      <text class="detail-label">月度产出</text>
      <text class="detail-value">
        灵植 {{herbYieldText}} / 灵矿 {{oreYieldText}} / 修为 {{cultivationGainText}}
      </text>
    </view>
    <view class="detail-cell">
      <text class="detail-label">下一次升级</text>
      <text class="detail-value">{{nextUpgradeSpiritStoneText}} 灵石</text>
    </view>
  </view>
  <view class="status-note">{{facility.summary}}</view>
  <view wx:if="{{facility.is_function_unlocked}}" class="status-note">
    {{facility.function_unlock_text}}
  </view>
</view>
