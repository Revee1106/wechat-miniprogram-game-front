.inspection-shell {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.inspection-tabs {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.inspection-tab {
  padding: 12rpx 0;
  border-radius: 999rpx;
  text-align: center;
  background: rgba(255, 250, 241, 0.88);
  color: var(--ink-soft);
  font-size: 22rpx;
}

.inspection-tab.active {
  background: var(--jade-main);
  color: #fff7ea;
}

.inspection-body {
  flex: 1;
  min-height: 0;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 250, 241, 0.88);
  border: 2rpx solid rgba(89, 66, 43, 0.12);
  box-sizing: border-box;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.info-card {
  padding: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 246, 226, 0.92);
}

.info-card.full {
  grid-column: 1 / -1;
}

.info-label {
  margin-bottom: 8rpx;
  color: var(--ink-faint);
  font-size: 20rpx;
}

.info-value {
  color: var(--ink-main);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.45;
}

.info-copy {
  color: var(--ink-soft);
  font-size: 23rpx;
  line-height: 1.6;
}
