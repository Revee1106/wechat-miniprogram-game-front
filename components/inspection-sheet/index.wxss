.inspection-shell {
  width: 100%;
}

.inspection-tabs {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.inspection-tab {
  padding: 16rpx 0;
  border-radius: 999rpx;
  text-align: center;
  background: rgba(255, 250, 241, 0.92);
  color: var(--ink-soft);
  font-size: 24rpx;
  border: 2rpx solid rgba(89, 66, 43, 0.12);
}

.inspection-tab.active {
  background: linear-gradient(135deg, var(--jade-main) 0%, var(--jade-soft) 100%);
  color: #fff7ea;
  box-shadow: 0 10rpx 20rpx rgba(32, 63, 58, 0.16);
}
