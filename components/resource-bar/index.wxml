<view class="panel">
  <view class="section-title">资源</view>
  <block wx:if="{{resources}}">
    <view class="resource-row">灵石：{{resources.spirit_stone}}</view>
    <view class="resource-row">药草：{{resources.herbs}}</view>
    <view class="resource-row">玄铁精华：{{resources.iron_essence}}</view>
  </block>
  <view wx:else class="muted-text">当前还没有资源快照。</view>
</view>
