<view class="panel">
  <view class="section-title">Current Event</view>
  <block wx:if="{{event}}">
    <view>{{event.template_name}}</view>
    <view class="muted-text">{{event.description}}</view>
    <view>Status: {{event.status}}</view>
  </block>
  <view wx:else class="muted-text">No pending event.</view>
</view>
