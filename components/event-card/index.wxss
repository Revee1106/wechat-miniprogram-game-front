.decision-card {
  padding: 28rpx 24rpx;
  border-radius: 34rpx;
  border: 2rpx solid rgba(68, 53, 36, 0.16);
  background: linear-gradient(180deg, rgba(253, 246, 231, 0.98) 0%, rgba(237, 223, 192, 0.98) 100%);
  box-shadow: 0 18rpx 40rpx rgba(48, 33, 18, 0.12);
}

.decision-kicker {
  margin-bottom: 14rpx;
  color: var(--clay-main);
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.decision-title {
  margin-bottom: 12rpx;
  color: var(--ink-main);
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
}

.decision-body {
  margin-bottom: 12rpx;
  color: var(--ink-main);
  font-size: 26rpx;
  line-height: 1.65;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 5;
  overflow: hidden;
}

.decision-meta,
.decision-note {
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.6;
}

.decision-note {
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
