<view class="panel">
  <view class="section-title">Player Status</view>
  <block wx:if="{{player}}">
    <view class="row">Realm: {{player.realm}}</view>
    <view class="row">Cultivation EXP: {{player.cultivation_exp}}</view>
    <view class="row">Lifespan: {{player.lifespan_current}} / {{player.lifespan_max}}</view>
    <view class="row">Luck: {{player.luck}}</view>
    <view wx:if="{{player.is_dead}}" class="danger-text">This character has fallen.</view>
  </block>
  <view wx:else class="muted-text">No active character yet.</view>
</view>
