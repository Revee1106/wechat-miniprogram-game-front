<view class="panel">
  <view class="scroll-kicker">命牌</view>
  <view class="section-title">今世身相</view>
  <block wx:if="{{player}}">
    <view class="detail-grid">
      <view class="detail-cell">
        <text class="detail-label">境界</text>
        <text class="detail-value">{{player.realm_display_name || player.realm}}</text>
      </view>
      <view class="detail-cell">
        <text class="detail-label">修为</text>
        <text class="detail-value">{{player.cultivation_exp}}</text>
      </view>
      <view class="detail-cell">
        <text class="detail-label">寿元</text>
        <text class="detail-value">{{lifespanText}}</text>
      </view>
      <view class="detail-cell">
        <text class="detail-label">气运</text>
        <text class="detail-value">{{player.luck}}</text>
      </view>
    </view>
    <view wx:if="{{player.is_dead}}" class="status-note danger death-note">此身寿尽，卷末已至。</view>
  </block>
  <view wx:else class="status-note">命牌未立，尚无今世可观。</view>
</view>
