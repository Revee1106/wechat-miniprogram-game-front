<view class="panel">
  <view class="section-title">可选行动</view>
  <block wx:if="{{displayChoices.length}}">
    <block wx:for="{{displayChoices}}" wx:key="option_id">
      <button
        class="secondary-button"
        data-option-id="{{item.option_id}}"
        bindtap="handleTap"
        disabled="{{loading || !item.is_available}}"
      >
        {{item.option_text}}
      </button>
      <view wx:if="{{item.is_default}}" class="muted-text">默认选项</view>
      <view wx:if="{{item.hasResourceRequirements}}" class="muted-text">
        需要资源：{{item.resourceText}}
      </view>
      <view wx:if="{{!item.is_available && item.disabled_reason}}" class="danger-text">
        {{item.disabled_reason}}
      </view>
    </block>
  </block>
  <view wx:else class="muted-text">当前没有可选项。</view>
</view>
