<view class="choice-panel">
  <view class="choice-title">此刻可选</view>
  <block wx:if="{{displayChoices.length}}">
    <block wx:for="{{displayChoices}}" wx:key="option_id">
      <view class="choice-entry">
        <button
          class="{{item.buttonClass}}"
          data-option-id="{{item.option_id}}"
          bindtap="handleTap"
          disabled="{{item.isDisabled}}"
        >
          {{item.displayText}}
        </button>
        <view wx:if="{{item.hasResourceRequirements}}" class="choice-note muted-text">条件：{{item.resourceText}}</view>
        <view wx:if="{{item.showDisabledReason}}" class="choice-note danger-text">
          {{item.disabledReason}}
        </view>
      </view>
    </block>
  </block>
  <view wx:else class="status-note">当前没有可执行的选项。</view>
</view>
