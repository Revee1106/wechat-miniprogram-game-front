<view class="panel">
  <view class="section-title">可选行动</view>
  <block wx:if="{{choices.length}}">
    <block wx:for="{{choices}}" wx:key="key">
      <button
        class="secondary-button"
        data-choice-key="{{item.key}}"
        bindtap="handleTap"
      >
        {{item.display_name}}
      </button>
      <view class="muted-text">{{item.description}}</view>
    </block>
  </block>
  <view wx:else class="muted-text">当前没有可选项。</view>
</view>
