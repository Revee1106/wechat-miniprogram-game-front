<view class="cover-page">
  <view class="cover-panel">
    <view class="cover-mark">山海异志</view>
    <view class="cover-title">此卷待启</view>
    <view class="cover-copy">只取一念，只行一步。先启程，再看此世会把你引向何处。</view>
    <button class="primary-button cover-action" bindtap="createRun" loading="{{loading}}">
      启程
    </button>
  </view>

  <view wx:if="{{error}}" class="status-note danger cover-error">{{error}}</view>
</view>
