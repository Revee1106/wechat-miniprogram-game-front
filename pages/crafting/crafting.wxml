<view class="scroll-page compact-page">
  <view class="compact-hero panel">
    <view class="compact-hero-main">
      <view>
        <view class="scroll-kicker">丹房火候</view>
        <view class="scroll-title">开炉炼丹</view>
        <view class="scroll-subtitle">把丹方、炉次和库存拆进横向面板里处理，减少整页下拉。</view>
      </view>
      <button class="ghost-button hero-return-button" bindtap="returnToJourney">返回行程</button>
    </view>

    <view class="hero-metrics">
      <view class="hero-chip">
        <view class="hero-chip-label">炼丹术</view>
        <view class="hero-chip-value">{{alchemy_state ? alchemy_state.mastery_title : "未入门"}}</view>
      </view>
      <view class="hero-chip">
        <view class="hero-chip-label">药草</view>
        <view class="hero-chip-value">{{run ? run.resources.herbs : 0}}</view>
      </view>
      <view class="hero-chip">
        <view class="hero-chip-label">灵泉水</view>
        <view class="hero-chip-value">{{spiritSpringWaterAmount}}</view>
      </view>
    </view>
  </view>

  <view class="compact-tabs">
    <view
      wx:for="{{panelTabs}}"
      wx:key="id"
      class="compact-tab {{item.active ? 'is-active' : ''}}"
      data-panel="{{item.id}}"
      bindtap="switchPanel"
    >
      {{item.label}}
    </view>
  </view>

  <swiper class="compact-swiper" current="{{currentPanelIndex}}" bindchange="handlePanelSwipe">
    <swiper-item>
      <view class="compact-panel">
        <view wx:if="{{recipeCards.length}}" class="recipe-tag-grid">
          <view
            wx:for="{{recipeCards}}"
            wx:key="recipe_id"
            class="recipe-tag {{selectedRecipeId === item.recipe_id ? 'is-selected' : ''}}"
            data-recipe-id="{{item.recipe_id}}"
            bindtap="openRecipeSheet"
          >
            <view class="recipe-tag-title">{{item.display_name}}</view>
            <view class="recipe-tag-meta">{{item.can_start ? "可开炉" : "已学丹方"}}</view>
          </view>
        </view>
        <view wx:else class="status-note overview-note">快去学习丹方吧</view>
      </view>
    </swiper-item>

    <swiper-item>
      <view class="compact-panel">
        <view class="section-title">当前炉次</view>
        <view wx:if="{{alchemy_state && alchemy_state.active_job}}" class="status-note overview-note">
          {{alchemy_state.active_job.recipe_name}} 仍需 {{alchemy_state.active_job.remaining_months}} 月完成。
        </view>
        <view wx:else class="status-note overview-note">当前没有在炼丹方，可先前往丹方页签起炉。</view>

        <view class="job-grid">
          <view class="detail-cell">
            <text class="detail-label">熟练度</text>
            <text class="detail-value">{{alchemy_state ? alchemy_state.mastery_exp : 0}}</text>
          </view>
          <view class="detail-cell">
            <text class="detail-label">灵石</text>
            <text class="detail-value">{{run ? run.resources.spirit_stone : 0}}</text>
          </view>
        </view>

        <view wx:if="{{alchemy_state && alchemy_state.last_result}}" class="status-note overview-note">
          最近结果：{{alchemy_state.last_result.summary}}
        </view>
      </view>
    </swiper-item>

    <swiper-item>
      <view class="compact-panel">
        <view class="panel-heading">
          <view class="section-title">成丹库存</view>
          <view class="muted-text">左右滑动查看成丹卡，直接服用。</view>
        </view>
        <scroll-view
          wx:if="{{inventoryCards.length}}"
          class="card-rail"
          scroll-x="{{true}}"
          enable-flex="{{true}}"
          show-scrollbar="{{false}}"
        >
          <view class="rail-track">
            <view wx:for="{{inventoryCards}}" wx:key="inventoryKey" class="inventory-card inventory-card--{{item.qualityTone}}">
              <view class="quality-pill quality-pill--{{item.qualityTone}}">{{item.qualityLabel}}</view>
              <view class="recipe-title">{{item.display_name}}</view>
              <view class="recipe-copy">数量 {{item.amount}}</view>
              <view class="recipe-copy">{{item.effectText}}</view>
              <button
                class="primary-button compact-action"
                data-item-id="{{item.item_id}}"
                data-quality="{{item.quality}}"
                bindtap="consumeItem"
                loading="{{loadingInventoryKey === item.inventoryKey}}"
              >
                服用
              </button>
            </view>
          </view>
        </scroll-view>
        <view wx:else class="status-note overview-note">丹室暂无成丹，先起一炉吧。</view>
      </view>
    </swiper-item>
  </swiper>

  <view
    wx:if="{{recipeSheetVisible && selectedRecipeCard}}"
    class="recipe-sheet-mask"
    bindtap="closeRecipeSheet"
  ></view>
  <view wx:if="{{recipeSheetVisible && selectedRecipeCard}}" class="recipe-sheet-panel">
    <view class="recipe-sheet-handle"></view>
    <view class="recipe-sheet-head">
      <view>
        <view class="scroll-kicker">丹方详情</view>
        <view class="recipe-sheet-title">{{selectedRecipeCard.display_name}}</view>
      </view>
      <button class="ghost-button recipe-sheet-close" bindtap="closeRecipeSheet">收起</button>
    </view>

    <scroll-view class="recipe-sheet-content" scroll-y="{{true}}">
      <view class="recipe-sheet-block">
        <view class="recipe-sheet-label">丹方说明</view>
        <view class="recipe-sheet-copy">{{selectedRecipeCard.description}}</view>
      </view>
      <view class="recipe-sheet-block">
        <view class="recipe-sheet-label">炼制信息</view>
        <view class="recipe-sheet-copy">
          耗时 {{selectedRecipeCard.duration_months}} 月 / 基础成功率 {{selectedRecipeCard.base_success_rate}}
        </view>
      </view>
      <view class="recipe-sheet-block">
        <view class="recipe-sheet-label">主材需求</view>
        <view class="recipe-sheet-copy">{{selectedRecipeCard.ingredientsText}}</view>
      </view>
      <view wx:if="{{selectedRecipeCard.disabled_reason}}" class="recipe-sheet-block">
        <view class="recipe-sheet-label">当前限制</view>
        <view class="recipe-sheet-copy">{{selectedRecipeCard.disabled_reason}}</view>
      </view>
    </scroll-view>

    <view class="recipe-sheet-actions">
      <button
        class="primary-button recipe-sheet-button"
        data-recipe-id="{{selectedRecipeCard.recipe_id}}"
        bindtap="startAlchemy"
        loading="{{loadingRecipeId === selectedRecipeCard.recipe_id}}"
        disabled="{{!selectedRecipeCard.can_start}}"
      >
        开炉
      </button>
    </view>
  </view>

  <view wx:if="{{error}}" class="status-note danger compact-error">{{error}}</view>
</view>
