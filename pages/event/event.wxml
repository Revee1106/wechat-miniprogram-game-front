<view class="flow-page">
  <block wx:if="{{currentEvent}}">
    <view class="flow-topbar">
      <view class="flow-mark">异闻当前</view>
    </view>
    <scroll-view class="decision-stage" scroll-y="{{true}}" show-scrollbar="{{false}}">
      <event-card event="{{currentEvent}}" />
      <choice-button-list
        choices="{{currentEventChoices}}"
        choicePattern="{{currentEvent.choice_pattern}}"
        loading="{{loading}}"
        bind:choose="handleChoice"
      />
    </scroll-view>
  </block>

  <block wx:else>
    <view class="journey-stage-rest">
      <view class="{{journeyOverviewClass}}">
        <block wx:if="{{showDwellingOverview}}">
          <view class="journey-overview-head">
            <view>
              <view class="dwelling-overview-title">洞府</view>
            </view>
            <view class="overview-pill">洞府等级 {{dwellingLevel}}</view>
          </view>
          <view class="journey-result dwelling-finance-result">
            <view class="journey-result-label">每月收支</view>
            <view
              wx:for="{{dwellingSettlementHistoryDisplay}}"
              wx:key="historyKey"
              class="journey-result-item"
              style="{{item.opacityStyle}}"
            >
              <view class="journey-result-summary">{{item.summary}}</view>
              <view
                wx:for="{{item.impactLines}}"
                wx:for-item="line"
                wx:for-index="lineIndex"
                wx:key="lineIndex"
                class="journey-result-impact"
              >
                {{line}}
              </view>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="journey-overview-head">
            <view>
              <view class="journey-kicker">当前行程</view>
              <view class="journey-title">已行 {{elapsedText}}</view>
              <view class="journey-meta">剩余寿元 {{lifespanText}}</view>
            </view>
            <view class="overview-pill">{{realmDisplayText}}</view>
          </view>
          <view class="journey-copy">{{journeySummary}}</view>
          <view wx:if="{{eventHistoryDisplay.length}}" class="journey-result">
            <view class="journey-result-label">事件结果</view>
            <view
              wx:for="{{eventHistoryDisplay}}"
              wx:key="historyKey"
              class="journey-result-item"
              style="{{item.opacityStyle}}"
            >
              <view class="journey-result-summary">{{item.summary}}</view>
              <view
                wx:for="{{item.impactLines}}"
                wx:for-item="line"
                wx:for-index="lineIndex"
                wx:key="lineIndex"
                class="journey-result-impact"
              >
                {{line}}
              </view>
            </view>
          </view>
        </block>
      </view>

      <view class="journey-main-stage">
        <block wx:if="{{showPlayerSection}}">
          <view class="section-card">
            <view class="section-head">
              <view class="section-title">命牌</view>
              <view class="section-copy">保留最关键的人物信息，不重复顶部已展示的寿元。</view>
            </view>
            <view class="section-grid">
              <view class="section-metric">
                <view class="metric-label">境界</view>
                <view class="metric-value">{{realmDisplayText}}</view>
              </view>
              <view class="section-metric">
                <view class="metric-label">修为</view>
                <view class="metric-value">{{cultivationDisplayText}}</view>
              </view>
              <view class="section-metric full">
                <view class="metric-label">气运</view>
                <view class="metric-value">{{luckDisplayText}}</view>
              </view>
            </view>
            <button class="primary-button stage-action" bindtap="advanceTime" loading="{{loading}}">
              推进时间
            </button>
          </view>
        </block>

        <block wx:elif="{{showResourcesSection}}">
          <view class="section-card">
            <view class="section-head">
              <view class="section-title">行囊</view>
              <view class="section-copy">查看当前修行资源，并将灵石转修为或把药草、灵植、灵矿变现。</view>
            </view>
            <view class="section-grid inventory-grid">
              <view
                wx:for="{{inventoryCards}}"
                wx:key="resourceKey"
                class="{{item.cardClass}}"
                data-resource-key="{{item.resourceKey}}"
                bindtap="openInventoryActionSheet"
              >
                <view class="metric-label">{{item.displayName}}</view>
                <view class="metric-value">{{item.amount}}</view>
              </view>
            </view>
            <button class="primary-button stage-action" bindtap="advanceTime" loading="{{loading}}">
              推进时间
            </button>
          </view>
        </block>

        <block wx:elif="{{showCultivationSection}}">
          <view class="section-card">
            <view class="section-head">
              <view class="section-title">修炼</view>
              <view class="section-copy">修为足够后，可以在此直接尝试破境。</view>
            </view>
            <view class="status-banner">{{breakthroughHint}}</view>
            <breakthrough-panel
              player="{{player}}"
              resources="{{resources}}"
              canBreakthrough="{{canBreakthrough}}"
              hint="{{breakthroughHint}}"
              breakthroughTargetExp="{{breakthroughTargetExp}}"
              breakthroughTargetSpiritStone="{{breakthroughTargetSpiritStone}}"
              bind:breakthrough="attemptBreakthrough"
            />
          </view>
        </block>

        <block wx:elif="{{showDwellingSection}}">
          <view class="section-card">
            <view class="dwelling-entry-grid">
              <view class="entry-card dwelling-entry-card" bindtap="openDwellingPage">
                <view class="entry-card-title">洞府营建</view>
                <view class="entry-card-copy">查看设施详情，执行建造、升级和月度运转检查。</view>
              </view>
            </view>
          </view>
        </block>
      </view>

      <view class="journey-dock">
        <inspection-sheet
          activeSection="{{activeSection}}"
          player="{{player}}"
          resources="{{resources}}"
          dwellingLevel="{{dwellingLevel}}"
          canBreakthrough="{{canBreakthrough}}"
          breakthroughHint="{{breakthroughHint}}"
          breakthroughTargetExp="{{breakthroughTargetExp}}"
          breakthroughTargetSpiritStone="{{breakthroughTargetSpiritStone}}"
          bind:change="handleSectionChange"
        />
      </view>
    </view>
  </block>

  <view
    wx:if="{{inventoryActionSheetVisible}}"
    class="sale-sheet-mask"
    bindtap="closeInventoryActionSheet"
  >
    <view class="sale-sheet sale-sheet-panel" catchtap="noop">
      <view class="sale-sheet-head">
        <view>
          <view class="sale-sheet-title">{{selectedInventoryResource.displayName}}</view>
          <view class="sale-sheet-copy">库存 {{selectedInventoryResource.amount}}</view>
        </view>
        <button class="ghost-button sale-sheet-close" bindtap="closeInventoryActionSheet">收起</button>
      </view>

      <view wx:if="{{inventoryActionHasMultipleOptions}}" class="sale-action-group">
        <button
          wx:for="{{inventoryActionButtons}}"
          wx:key="actionKey"
          class="{{item.buttonClass}}"
          data-action-key="{{item.actionKey}}"
          bindtap="selectInventoryAction"
        >
          {{item.label}}
        </button>
      </view>
      <view wx:else class="sale-sheet-current-action">当前操作：{{inventoryActionCurrentLabel}}</view>

      <view class="sale-sheet-quantity">
        <button class="ghost-button sale-step-button" bindtap="decreaseInventoryActionQuantity">-1</button>
        <view class="sale-quantity-value">{{inventoryActionQuantity}}</view>
        <button class="ghost-button sale-step-button" bindtap="increaseInventoryActionQuantity">+1</button>
      </view>
      <view class="sale-sheet-shortcuts">
        <button class="ghost-button sale-shortcut-button" data-mode="half" bindtap="fillInventoryActionQuantity">半数</button>
        <button class="ghost-button sale-shortcut-button" data-mode="all" bindtap="fillInventoryActionQuantity">全部</button>
      </view>
      <view class="sale-sheet-total">可得 {{inventoryActionTotalText}}</view>
      <button
        class="primary-button sale-confirm-button"
        bindtap="confirmInventoryAction"
        loading="{{inventoryActionLoading}}"
        disabled="{{inventoryActionConfirmDisabled}}"
      >
        {{selectedInventoryAction.confirmLabel}}
      </button>
    </view>
  </view>

  <view
    wx:if="{{cultivationCapPromptVisible}}"
    class="cultivation-cap-sheet-mask"
    bindtap="cancelCultivationCapAdvance"
  >
    <view class="sale-sheet cultivation-cap-sheet-panel" catchtap="noop">
      <view class="sale-sheet-head">
        <view>
          <view class="sale-sheet-title">{{cultivationCapPromptTitle}}</view>
          <view class="sale-sheet-copy">{{cultivationCapPromptDescription}}</view>
        </view>
      </view>
      <button class="{{cultivationCapToggleClass}}" bindtap="toggleCultivationCapPromptSkip">
        不再提示
      </button>
      <view class="cultivation-cap-actions">
        <button class="ghost-button cultivation-cap-action-button" bindtap="cancelCultivationCapAdvance">
          {{cultivationCapPromptCancelText}}
        </button>
        <button class="primary-button cultivation-cap-action-button" bindtap="confirmCultivationCapAdvance">
          {{cultivationCapPromptConfirmText}}
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{error}}" class="status-note danger flow-error">{{error}}</view>
</view>
