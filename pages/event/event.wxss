@import "../../app.wxss";

.flow-page {
  height: 100vh;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.flow-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.flow-mark {
  color: #8c4d36;
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

.decision-stage {
  flex: 1;
  min-height: 0;
}

.journey-stage-rest {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.journey-overview,
.journey-main-stage {
  padding: 24rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(68, 53, 36, 0.14);
  background: linear-gradient(180deg, rgba(253, 246, 231, 0.98) 0%, rgba(237, 223, 192, 0.98) 100%);
  box-shadow: 0 16rpx 34rpx rgba(48, 33, 18, 0.1);
  box-sizing: border-box;
}

.journey-overview {
  flex: 0 0 360rpx;
  overflow: hidden;
}

.is-dwelling-overview {
  flex-basis: 248rpx;
  min-height: 248rpx;
}

.journey-overview-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.journey-kicker {
  margin-bottom: 10rpx;
  color: #8c4d36;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.dwelling-overview-title {
  margin-bottom: 10rpx;
  color: #1f1a17;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.journey-title {
  margin-bottom: 10rpx;
  color: #1f1a17;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.2;
}

.journey-meta {
  margin-bottom: 12rpx;
  color: #5e5141;
  font-size: 28rpx;
  line-height: 1.5;
}

.overview-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(32, 63, 58, 0.1);
  color: #203f3a;
  font-size: 22rpx;
}

.journey-copy {
  color: #5e5141;
  font-size: 24rpx;
  line-height: 1.6;
}

.journey-result {
  margin-top: 14rpx;
  max-height: 162rpx;
  overflow: hidden;
}

.journey-result-label {
  margin-bottom: 8rpx;
  color: #8c4d36;
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.journey-result-item {
  margin-bottom: 10rpx;
}

.journey-result-summary {
  color: #1f1a17;
  font-size: 23rpx;
  line-height: 1.5;
}

.journey-result-impact {
  color: #5e5141;
  font-size: 21rpx;
  line-height: 1.45;
}

.journey-main-stage {
  flex: 1;
  min-height: 0;
  display: flex;
}

.section-card {
  width: 100%;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-title {
  margin-bottom: 8rpx;
  color: #1f1a17;
  font-size: 34rpx;
  font-weight: 700;
}

.section-copy {
  color: #5e5141;
  font-size: 24rpx;
  line-height: 1.6;
}

.section-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.inventory-grid {
  margin-top: 4rpx;
  align-content: flex-start;
}

.inventory-card {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  box-shadow: none;
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.inventory-card.is-actionable {
  border-color: rgba(32, 63, 58, 0.18);
  box-shadow: 0 6rpx 14rpx rgba(32, 63, 58, 0.06);
}

.sale-sheet {
  margin-top: 16rpx;
}

.sale-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: flex-end;
  justify-content: stretch;
  background: rgba(21, 28, 27, 0.28);
}

.cultivation-cap-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 45;
  display: flex;
  align-items: flex-end;
  justify-content: stretch;
  background: rgba(21, 28, 27, 0.34);
}

.cultivation-cap-sheet-panel {
  width: 100%;
}

.cultivation-cap-toggle {
  width: 100%;
  margin-top: 16rpx;
}

.cultivation-cap-toggle.is-selected {
  color: #fff7ea;
  background: linear-gradient(135deg, #203f3a 0%, #365d57 100%);
  border-color: transparent;
}

.cultivation-cap-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
}

.cultivation-cap-action-button {
  width: 48%;
}

.sale-sheet-panel {
  width: 100%;
  padding: 22rpx 22rpx 46rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: linear-gradient(180deg, rgba(253, 246, 231, 0.99) 0%, rgba(237, 223, 192, 0.99) 100%);
  border-top: 2rpx solid rgba(68, 53, 36, 0.14);
  box-shadow: 0 -18rpx 34rpx rgba(48, 33, 18, 0.14);
}

.sale-sheet-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.sale-sheet-title {
  color: #1f1a17;
  font-size: 28rpx;
  font-weight: 700;
}

.sale-sheet-copy,
.sale-sheet-total {
  margin-top: 8rpx;
  color: #5e5141;
  font-size: 22rpx;
  line-height: 1.5;
}

.sale-sheet-current-action {
  margin-top: 14rpx;
  color: #5e5141;
  font-size: 22rpx;
  line-height: 1.5;
}

.sale-action-group {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 12rpx 0;
}

.sale-action-button {
  width: 48%;
  min-width: 0;
}

.sale-action-button.is-selected {
  color: #fff7ea;
  background: linear-gradient(135deg, #203f3a 0%, #365d57 100%);
  border-color: transparent;
}

.sale-sheet-close {
  width: auto;
  min-width: 140rpx;
}

.sale-sheet-quantity {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.sale-quantity-value {
  width: 120rpx;
  text-align: center;
  color: #1f1a17;
  font-size: 30rpx;
  font-weight: 700;
}

.sale-step-button {
  flex: 1;
  min-width: 0;
}

.sale-shortcut-button {
  width: 48%;
  min-width: 0;
}

.sale-sheet-shortcuts {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
}

.sale-confirm-button {
  margin-top: 14rpx;
}

.section-metric {
  width: 48%;
  margin-bottom: 14rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 241, 0.9);
  border: 2rpx solid rgba(89, 66, 43, 0.1);
  box-sizing: border-box;
}

.section-metric.full {
  width: 100%;
}

.metric-label {
  margin-bottom: 4rpx;
  color: #857661;
  font-size: 20rpx;
}

.metric-value {
  color: #1f1a17;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.3;
}

.stage-action {
  margin-top: auto;
}

.status-banner {
  margin-bottom: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(140, 77, 54, 0.08);
  color: #5e5141;
  font-size: 24rpx;
  line-height: 1.6;
}

.dwelling-finance-result {
  margin-top: 24rpx;
}

.dwelling-entry-grid {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
}

.dwelling-entry-card {
  width: 48%;
  min-height: 188rpx;
  margin-bottom: 0;
  text-align: left;
  box-sizing: border-box;
}

.journey-dock {
  flex-shrink: 0;
  padding: 18rpx 20rpx 22rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(68, 53, 36, 0.12);
  background: linear-gradient(180deg, rgba(255, 248, 235, 0.96) 0%, rgba(236, 222, 191, 0.96) 100%);
  box-shadow: 0 12rpx 26rpx rgba(48, 33, 18, 0.08);
}

.flow-error {
  margin-top: 12rpx;
}
