@import "../../app.wxss";

.flow-page {
  height: 100vh;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.flow-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.flow-mark {
  color: var(--clay-main);
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

.decision-stage {
  flex: 1;
  min-height: 0;
}

.journey-stage-rest {
  flex: 1;
  min-height: 0;
  display: grid;
  grid-template-rows: auto 1fr auto;
  gap: 18rpx;
}

.journey-overview,
.journey-main-stage {
  padding: 24rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(68, 53, 36, 0.14);
  background: linear-gradient(180deg, rgba(253, 246, 231, 0.98) 0%, rgba(237, 223, 192, 0.98) 100%);
  box-shadow: 0 16rpx 34rpx rgba(48, 33, 18, 0.1);
  box-sizing: border-box;
}

.journey-overview-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.journey-kicker {
  margin-bottom: 10rpx;
  color: var(--clay-main);
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.journey-title {
  margin-bottom: 10rpx;
  color: var(--ink-main);
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.2;
}

.journey-meta {
  margin-bottom: 12rpx;
  color: var(--ink-soft);
  font-size: 28rpx;
  line-height: 1.5;
}

.overview-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(32, 63, 58, 0.1);
  color: var(--jade-main);
  font-size: 22rpx;
}

.journey-copy {
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.journey-result {
  margin-top: 14rpx;
  max-height: 162rpx;
  overflow: hidden;
}

.journey-result-label {
  margin-bottom: 8rpx;
  color: var(--clay-main);
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.journey-result-item {
  margin-bottom: 10rpx;
}

.journey-result-summary {
  color: var(--ink-main);
  font-size: 23rpx;
  line-height: 1.5;
}

.journey-result-impact {
  color: var(--ink-soft);
  font-size: 21rpx;
  line-height: 1.45;
}

.journey-main-stage {
  min-height: 0;
  display: flex;
}

.section-card {
  width: 100%;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-title {
  margin-bottom: 8rpx;
  color: var(--ink-main);
  font-size: 34rpx;
  font-weight: 700;
}

.section-copy {
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.section-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.inventory-sale-panel {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 250, 242, 0.9);
  border: 2rpx solid rgba(89, 66, 43, 0.1);
}

.inventory-sale-title {
  margin-bottom: 6rpx;
  font-size: 28rpx;
}

.inventory-sale-copy {
  font-size: 22rpx;
}

.inventory-sale-card {
  cursor: pointer;
}

.inventory-sale-grid {
  margin-top: 16rpx;
}

.inventory-sale-meta {
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.5;
}

.sale-sheet {
  margin-top: 16rpx;
}

.sale-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: flex-end;
  justify-content: stretch;
  background: rgba(21, 28, 27, 0.28);
}

.sale-sheet-panel {
  width: 100%;
  padding: 22rpx 22rpx calc(22rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: linear-gradient(180deg, rgba(253, 246, 231, 0.99) 0%, rgba(237, 223, 192, 0.99) 100%);
  border-top: 2rpx solid rgba(68, 53, 36, 0.14);
  box-shadow: 0 -18rpx 34rpx rgba(48, 33, 18, 0.14);
}

.sale-sheet-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.sale-sheet-title {
  color: var(--ink-main);
  font-size: 28rpx;
  font-weight: 700;
}

.sale-sheet-copy,
.sale-sheet-total {
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.5;
}

.sale-sheet-close {
  width: auto;
  min-width: 140rpx;
}

.sale-sheet-quantity {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 120rpx 1fr;
  gap: 12rpx;
  align-items: center;
}

.sale-quantity-value {
  text-align: center;
  color: var(--ink-main);
  font-size: 30rpx;
  font-weight: 700;
}

.sale-step-button,
.sale-shortcut-button {
  min-width: 0;
}

.sale-sheet-shortcuts {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.sale-confirm-button {
  margin-top: 14rpx;
}

.inventory-empty-note {
  margin-top: 16rpx;
}

.section-metric {
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 241, 0.9);
  border: 2rpx solid rgba(89, 66, 43, 0.1);
}

.section-metric.full {
  grid-column: 1 / -1;
}

.metric-label {
  margin-bottom: 8rpx;
  color: var(--ink-faint);
  font-size: 21rpx;
}

.metric-value {
  color: var(--ink-main);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.stage-action {
  margin-top: auto;
}

.status-banner {
  margin-bottom: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(140, 77, 54, 0.08);
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.dwelling-summary-card {
  padding: 22rpx 22rpx 20rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(68, 53, 36, 0.12);
  background: linear-gradient(180deg, rgba(255, 250, 240, 0.96) 0%, rgba(238, 225, 196, 0.96) 100%);
  box-shadow: 0 14rpx 28rpx rgba(48, 33, 18, 0.08);
}

.dwelling-summary-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.dwelling-summary-label {
  margin-bottom: 8rpx;
  color: var(--clay-main);
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.dwelling-summary-title {
  color: var(--ink-main);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.dwelling-summary-pill {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(32, 63, 58, 0.1);
  color: var(--jade-main);
  font-size: 22rpx;
}

.dwelling-summary-copy,
.dwelling-summary-note {
  margin-top: 14rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.dwelling-summary-note {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(140, 77, 54, 0.08);
}

.dwelling-entry-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.dwelling-entry-card {
  min-height: 188rpx;
  margin-bottom: 0;
  text-align: left;
  box-sizing: border-box;
}

.journey-dock {
  padding: 18rpx 20rpx 22rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(68, 53, 36, 0.12);
  background: linear-gradient(180deg, rgba(255, 248, 235, 0.96) 0%, rgba(236, 222, 191, 0.96) 100%);
  box-shadow: 0 12rpx 26rpx rgba(48, 33, 18, 0.08);
}

.flow-error {
  margin-top: 12rpx;
}
