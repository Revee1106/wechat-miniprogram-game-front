@import "../../app.wxss";

.compact-page {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.compact-hero {
  margin-bottom: 0;
}

.compact-hero-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.hero-return-button {
  width: auto;
  min-width: 220rpx;
}

.compact-panel {
  flex: 1;
  min-height: 0;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(68, 53, 36, 0.14);
  background: linear-gradient(180deg, rgba(253, 246, 231, 0.98) 0%, rgba(237, 223, 192, 0.98) 100%);
  box-shadow: 0 16rpx 34rpx rgba(48, 33, 18, 0.1);
  box-sizing: border-box;
}

.panel-heading {
  margin-bottom: 16rpx;
}

.facility-tag-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.facility-tag {
  min-height: 132rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 250, 242, 0.92);
  border: 2rpx solid rgba(89, 66, 43, 0.12);
  box-sizing: border-box;
}

.facility-tag.is-selected {
  border-color: rgba(32, 63, 58, 0.34);
  box-shadow: 0 10rpx 24rpx rgba(32, 63, 58, 0.14);
}

.facility-tag-top {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.facility-tag-title {
  color: var(--ink-main);
  font-size: 28rpx;
  font-weight: 700;
}

.facility-tag-level {
  color: var(--clay-main);
  font-size: 22rpx;
}

.facility-tag-status {
  margin-top: 12rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
}

.facility-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(33, 25, 17, 0.32);
  z-index: 20;
}

.facility-sheet-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  padding: 18rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: linear-gradient(180deg, rgba(253, 246, 231, 0.99) 0%, rgba(237, 223, 192, 0.99) 100%);
  box-shadow: 0 -18rpx 36rpx rgba(48, 33, 18, 0.16);
}

.facility-sheet-handle {
  width: 88rpx;
  height: 8rpx;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
  background: rgba(89, 66, 43, 0.18);
}

.facility-sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.sheet-title {
  margin-top: 6rpx;
  color: var(--ink-main);
  font-size: 34rpx;
  font-weight: 700;
}

.sheet-close-button {
  width: auto;
  min-width: 148rpx;
  margin: 0;
  padding: 0 24rpx;
}

.facility-sheet-content {
  max-height: 52vh;
  margin-top: 18rpx;
}

.facility-sheet-summary {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.sheet-chip {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 249, 237, 0.86);
  border: 2rpx solid rgba(89, 66, 43, 0.12);
}

.sheet-chip-label {
  margin-bottom: 6rpx;
  color: var(--ink-faint);
  font-size: 22rpx;
}

.sheet-chip-value {
  color: var(--ink-main);
  font-size: 28rpx;
  font-weight: 700;
}

.sheet-block {
  margin-bottom: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 242, 0.86);
  border: 2rpx solid rgba(89, 66, 43, 0.1);
}

.sheet-block-label {
  margin-bottom: 8rpx;
  color: var(--ink-faint);
  font-size: 22rpx;
}

.sheet-block-value {
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.facility-sheet-actions {
  margin-top: 18rpx;
}

.sheet-static-note {
  margin-top: 0;
}
