<view class="scroll-page compact-page">
  <view class="compact-hero panel">
    <view class="compact-hero-main">
      <view>
        <view class="scroll-kicker">洞府</view>
        <view class="scroll-title">洞府营建</view>
        <view class="scroll-subtitle">先选设施，再在底部详情里查看产出、消耗并完成营建。</view>
        <view class="scroll-subtitle">当前灵石 {{currentSpiritStone}}</view>
      </view>
      <button class="ghost-button hero-return-button" bindtap="returnToJourney">返回行程</button>
    </view>
  </view>

  <view class="compact-panel">
    <view class="panel-heading">
      <view class="section-title">设施操作</view>
      <view class="muted-text">点击方块标签后，再在底部抽屉里完成建造或升级。</view>
    </view>
    <view class="facility-tag-grid">
      <view
        wx:for="{{facilityCards}}"
        wx:key="facility_id"
        class="facility-tag {{selectedFacilityId === item.facility_id ? 'is-selected' : ''}}"
        data-facility-id="{{item.facility_id}}"
        bindtap="openFacilitySheet"
      >
        <view class="facility-tag-top">
          <view class="facility-tag-title">{{item.display_name}}</view>
          <view class="facility-tag-level">Lv.{{item.level}} / {{item.max_level}}</view>
        </view>
        <view class="facility-tag-status">{{item.statusText}}</view>
      </view>
    </view>
  </view>

  <view
    wx:if="{{facilitySheetVisible}}"
    class="facility-sheet-mask"
    bindtap="closeFacilitySheet"
  ></view>
  <view wx:if="{{facilitySheetVisible && selectedFacilityCard}}" class="facility-sheet-panel">
    <view class="facility-sheet-handle"></view>
    <view class="facility-sheet-header">
      <view>
        <view class="scroll-kicker">设施详情</view>
        <view class="sheet-title">{{selectedFacilityCard.display_name}}</view>
      </view>
      <button class="sheet-close-button" bindtap="closeFacilitySheet">收起</button>
    </view>

    <scroll-view class="facility-sheet-content" scroll-y="{{true}}">
      <view class="facility-sheet-summary">
        <view class="sheet-chip">
          <view class="sheet-chip-label">当前等级</view>
          <view class="sheet-chip-value">
            Lv.{{selectedFacilityCard.level}} / {{selectedFacilityCard.max_level}}
          </view>
        </view>
        <view class="sheet-chip">
          <view class="sheet-chip-label">当前状态</view>
          <view class="sheet-chip-value">{{selectedFacilityCard.statusText}}</view>
        </view>
      </view>

      <view class="sheet-block">
        <view class="sheet-block-label">本月产出</view>
        <view class="sheet-block-value">{{selectedFacilityCard.yieldText}}</view>
      </view>

      <view class="sheet-block">
        <view class="sheet-block-label">维护消耗</view>
        <view class="sheet-block-value">{{selectedFacilityCard.maintenanceText}}</view>
      </view>

      <view class="sheet-block">
        <view class="sheet-block-label">下次升级</view>
        <view class="sheet-block-value">{{selectedFacilityCard.nextUpgradeText}}</view>
      </view>

      <view class="sheet-block">
        <view class="sheet-block-label">设施说明</view>
        <view class="sheet-block-value">{{selectedFacilityCard.summary}}</view>
      </view>

      <view wx:if="{{selectedFacilityCard.is_function_unlocked}}" class="sheet-block">
        <view class="sheet-block-label">功能解锁</view>
        <view class="sheet-block-value">{{selectedFacilityCard.function_unlock_text}}</view>
      </view>
    </scroll-view>

    <view class="facility-sheet-actions">
      <button
        wx:if="{{selectedFacilityCard.actionType === 'build'}}"
        class="primary-button"
        data-facility-id="{{selectedFacilityCard.facility_id}}"
        bindtap="buildFacility"
        loading="{{loadingFacilityId === selectedFacilityCard.facility_id}}"
      >
        建造
      </button>
      <button
        wx:elif="{{selectedFacilityCard.actionType === 'upgrade'}}"
        class="primary-button"
        data-facility-id="{{selectedFacilityCard.facility_id}}"
        bindtap="upgradeFacility"
        loading="{{loadingFacilityId === selectedFacilityCard.facility_id}}"
      >
        升级
      </button>
      <view wx:else class="status-note sheet-static-note">已达当前版本最高等级</view>
    </view>
  </view>
</view>
