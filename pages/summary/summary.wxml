<view class="ending-page">
  <view class="ending-panel">
    <view class="ending-mark">此世终卷</view>
    <view class="ending-title">卷尾已定</view>
    <view wx:if="{{resultSummary}}" class="ending-copy">{{resultSummary}}</view>
    <view wx:else class="ending-copy">{{defaultResultSummary}}</view>
  </view>

  <run-result-modal
    visible="{{isDead}}"
    title="此世终卷"
    message="{{resultSummary}}"
    actionText="转生再启"
    bind:confirm="handleRebirth"
  />

  <view wx:if="{{playerProfile}}" class="ending-meta">
    <view class="ending-stat">
      <view class="ending-stat-label">累计转生</view>
      <view class="ending-stat-value">{{playerProfile.total_rebirth_count}}</view>
    </view>
    <view class="ending-stat">
      <view class="ending-stat-label">永久气运</view>
      <view class="ending-stat-value">{{playerProfile.permanent_luck_bonus}}</view>
    </view>
  </view>
  <view wx:if="{{error}}" class="status-note danger">{{error}}</view>
</view>
